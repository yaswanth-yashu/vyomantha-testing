# Gemini API key — reserved for Voice Agent only
GEMINI_API_KEY="your_key_here"

# Rotated keys for General Tutor & other pages (add any number: _1, _2, _3, ...)
GEMINI_API_KEY_1="your_key_here"
GEMINI_API_KEY_2="your_key_here"
GEMINI_API_KEY_3="your_key_here"
GEMINI_API_KEY_4="your_key_here"

# Add these for Frappe integration
FRAPPE_URL="https://your-frappe-site.com"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Voice server URL (for Vercel deployment)
# Set this to your Render WebSocket server URL
# Example: wss://lms-voice.onrender.com
# On localhost, auto-uses ws://localhost:5001
NEXT_PUBLIC_WS_URL=
