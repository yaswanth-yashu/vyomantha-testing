# ==========================================
# FRONTEND CONFIGURATION (Vercel Deployment)
# ==========================================

# Gemini API Keys (For chat and tutoring features)
GEMINI_API_KEY="your-main-gemini-key"
GEMINI_API_KEY_1="rotated-key-1-optional"
GEMINI_API_KEY_2="rotated-key-2-optional"

# Next.js Server Authentication
NEXTAUTH_SECRET="generate-a-long-random-string-here"

# WebSockets Voice Tutor Service (Points to your Render Voice server)
# Format: wss://<your-render-service-name>.onrender.com
NEXT_PUBLIC_WS_URL="wss://your-voice-server.onrender.com"

# Frappe LMS Backend Service (Points to your hosted Frappe instance)
# Leave blank to run frontend in Offline LocalStorage Simulation Mode
FRAPPE_URL="https://your-frappe-backend-url.com"
NEXT_PUBLIC_FRAPPE_URL="https://your-frappe-backend-url.com"

# Upstash Redis Connection (Used for short term memory caching)
UPSTASH_REDIS_REST_URL="https://your-database-name.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# Database Connection (MySQL/TiDB for the Resource Library)
DB_HOST="your-tidb-or-mysql-host.com"
DB_PORT="4000"
DB_USER="your-database-user"
DB_PASSWORD="your-database-password"
DB_NAME="sys"
DB_SSL="true"  # Set to true for secure cloud databases like TiDB Cloud

NEXT_PUBLIC_WS_URL=''
